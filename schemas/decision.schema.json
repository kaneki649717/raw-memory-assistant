{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Working Memory Decision",
  "type": "object",
  "required": ["id", "eventId", "sessionId", "title", "decisionText"],
  "properties": {
    "id": { "type": "string" },
    "eventId": { "type": "string" },
    "sessionId": { "type": "string" },
    "title": { "type": "string" },
    "decisionText": { "type": "string" },
    "whyText": { "type": "string" },
    "outcomeText": { "type": "string" },
    "files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "configKeys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "createdAt": { "type": "string", "description": "ISO timestamp" }
  }
}
